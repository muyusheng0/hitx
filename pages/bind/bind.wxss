.container {
  padding: 100rpx 50rpx;
}

.header {
  text-align: center;
  margin-bottom: 100rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  color: #2c3e50;
  font-weight: bold;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 20rpx;
}

.form {
  background: #fff;
  padding: 50rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.input {
  border: 1px solid #ddd;
  border-radius: 10rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
  font-size: 28rpx;
}

.btn {
  background: #e74c3c;
  color: #fff;
  border-radius: 10rpx;
  margin-top: 30rpx;
}
