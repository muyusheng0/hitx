.container {
  padding: 30rpx;
}

.input-area {
  background: #fff;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.textarea {
  width: 100%;
  height: 150rpx;
  border: 1px solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.btn {
  background: #e74c3c;
  color: #fff;
  margin-top: 20rpx;
}

.messages {
  padding: 0 10rpx;
}

.message-item {
  background: #fff;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.nickname {
  font-size: 30rpx;
  color: #e74c3c;
  font-weight: bold;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}