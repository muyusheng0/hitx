.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  padding: 60rpx 0;
}

.title {
  font-size: 56rpx;
  color: #2c3e50;
  font-weight: bold;
}

.subtitle {
  font-size: 32rpx;
  color: #e74c3c;
  margin-top: 10rpx;
}

.stats {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 72rpx;
  color: #e74c3c;
  font-weight: bold;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
}

.section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 36rpx;
  color: #2c3e50;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.message-item {
  background: #fff;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.message-nickname {
  display: block;
  font-size: 28rpx;
  color: #e74c3c;
  font-weight: bold;
}

.message-content {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-top: 10rpx;
}
