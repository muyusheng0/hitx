<view class="container">
  <view class="profile-card" wx:if="{{profile}}">
    <image class="avatar" src="{{profile.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
    <text class="name">{{profile.name}}</text>
    <text class="info">{{profile.city || profile.hometown_name}}</text>
  </view>

  <view class="info-list">
    <view class="info-item">
      <text class="label">学号</text>
      <text class="value">{{profile.id}}</text>
    </view>
    <view class="info-item">
      <text class="label">电话</text>
      <text class="value">{{profile.phone || '未填写'}}</text>
    </view>
    <view class="info-item">
      <text class="label">工作</text>
      <text class="value">{{profile.work || '未填写'}}</text>
    </view>
    <view class="info-item">
      <text class="label">公司</text>
      <text class="value">{{profile.company || '未填写'}}</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>