.container {
  padding: 30rpx;
}

.profile-card {
  background: linear-gradient(135deg, #2c3e50, #3498db);
  padding: 60rpx 30rpx;
  border-radius: 20rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 30rpx;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: 5rpx solid #fff;
}

.name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.info {
  display: block;
  font-size: 28rpx;
  margin-top: 10rpx;
  opacity: 0.8;
}

.info-list {
  background: #fff;
  border-radius: 10rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1px solid #eee;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.logout-btn {
  margin-top: 50rpx;
  color: #999;
}